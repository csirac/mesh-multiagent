anthropic-shim/shim.yaml

# Root-level scratch files
/*.pdf
# /*.txt — disabled; requirements.txt must be tracked
artifacts/

# Benchmark result data (large, machine-specific)
benchmark/results/

# Token/credential backups
*.backup*

# Timestamped edit backups (rollback copies made before in-place edits)
*.bak
*.bak-*
*~

# Accidental tilde-expansion directory (a dir literally named "~")
/~/

# Tool cache/marker files
.codex
data-gym-cache/

# Local data directories not for version control
downloads/
papers/
swebench_repo/

# Benchmark eval outputs
benchmark/agent_eval/results/

# LaTeX build products (track the .tex source only)
docs/*.aux
docs/*.out
docs/*.toc
docs/*.pdf
