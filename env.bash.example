# Mesh environment variables — copy to env.bash and fill in your values.
#
# Usage:
#   cp env.bash.example env.bash
#   # Edit env.bash with your API keys
#   source env.bash

# ─── Required ───────────────────────────────────────────────────────────────

# Shared auth token for router <-> agent registration.
# Generate one with: openssl rand -hex 32
export MESH_AUTH_TOKEN="<generate-with-openssl-rand-hex-32>"

# At least one LLM API key is required. OpenAI is the simplest default.
export OPENAI_API_KEY="sk-..."

# ─── Optional (enable additional backends and features) ─────────────────────

# DeepSeek API (used for deepseek-direct backend and memory formation)
# export DEEPSEEK_API_KEY=""

# Google Gemini API
# export GOOGLE_API_KEY=""

# Z.AI API (GLM models)
# export ZAI_API_KEY=""

# Exa web search API (used by exa_search tool)
# export EXA_API_KEY=""

# OpenRouter API (multi-model routing)
# export OPENROUTER_API_KEY=""

# Synthetic.ai API (used by synthetic-thinking backends)
# export SYNTHETIC_API_KEY=""

# ─── Notes server (optional) ────────────────────────────────────────────────

# Remote notes server for the notes_* tools
# export RN_API_TOKEN=""
# export RN_SERVER_BASE="https://your-notes-server.example.com"

# ─── File attachments (optional) ────────────────────────────────────────────

# HMAC secret for signed attachment URLs. Generate with: openssl rand -hex 32
# export MESH_ATTACHMENT_SECRET=""
